# 阿里云 AccessKey（在阿里云控制台 -> AccessKey 管理中获取）
# 安全提示：建议使用 RAM 子账号的 AccessKey，只授予短信发送权限
ALIYUN_ACCESS_KEY_ID=你的AccessKeyId
ALIYUN_ACCESS_KEY_SECRET=你的AccessKeySecret

# 短信签名和模板（在阿里云短信服务控制台中配置）
# 签名：你在阿里云申请通过的短信签名，比如"生音科技"
# 模板：你在阿里云申请通过的模板CODE，比如 SMS_123456789
SMS_SIGN_NAME=生音科技
SMS_TEMPLATE_CODE=100001

# 服务端口
PORT=3001

# TODO: 微信开放平台（上线时填写）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# TODO: QQ 互联（上线时填写）
QQ_APP_ID=
QQ_APP_KEY=
