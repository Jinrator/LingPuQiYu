# 后端 API 地址（本地开发时指向你的后端服务）
VITE_API_BASE=http://localhost:3001

# CORS 允许的前端域名（逗号分隔，留空则允许所有来源，仅限开发环境）
# 生产环境务必配置，例如：https://your-app.vercel.app
ALLOWED_ORIGINS=

# 当前采用"自有后端鉴权 + Supabase 只做数据库"模式
# 前端不直接写 Supabase，以下变量仅为后续扩展预留
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Gemini API（可选）
GEMINI_API_KEY=
